:root {
    --color-text-dark: rgb(9, 9, 31);
    --color-text-light: rgb(255, 255, 255);
    --radius-default: 15px;
    --duration-fade: 0.35s;
}

.rounded {
    border-top-left-radius: var(--radius-default);
    border-top-right-radius: var(--radius-default);
    border-bottom-right-radius: var(--radius-default);
    border-bottom-left-radius: var(--radius-default);
}

.popup-window {
    align-self: center;
    align-items: stretch;
    width: 800px;
    height: 528px;
    top: auto;
    background-color: rgb(161, 161, 161);
    padding: 12px;
}

.popup-title-container {
    flex-grow: 0;
    flex-shrink: 0;
    flex-basis: 100px;
    background-color: rgb(14, 14, 14);
}

.popup-title {
    flex-grow: 1;
    -unity-text-align: middle-center;
    -unity-font-style: bold;
    font-size: 55px;
    color: var(--color-text-light);
}

.stacked-button {
    margin-bottom: 15px;
}

.bordered-frame {
    background-color: rgba(207, 207, 207, 0);
    border-color: rgb(212, 212, 212);
    border-width: 4px;
    margin-top: 10px;
}

.level-item {
    flex-grow: 0;
    flex-shrink: 0;
    height: 100px;
    background-color: rgb(103, 103, 103);
    color: var(--color-text-light);
    width: 100px;
    border-top-width: 5px;
    border-right-width: 5px;
    border-bottom-width: 5px;
    border-left-width: 5px;
    border-left-color: rgb(0, 0, 0);
    border-right-color: rgb(0, 0, 0);
    border-top-color: rgb(0, 0, 0);
    border-bottom-color: rgb(0, 0, 0);
    margin: 15px;
}

.level-item:hover {
    background-color: rgb(82, 82, 82);
}

.level-item__selected-rect {
    position: absolute;
    left: -12px;
    top: -12px;
    right: -12px;
    bottom: -12px;
    border-width: 4px;
    border-top-width: 4px;
    border-right-width: 4px;
    border-bottom-width: 4px;
    border-left-width: 4px;
    border-left-color: rgb(255, 255, 255);
    border-right-color: rgb(255, 255, 255);
    border-top-color: rgb(255, 255, 255);
    border-bottom-color: rgb(255, 255, 255);
    opacity: 0;
}

.level-item__selected-rect:checked {
    opacity: 1;
    transition-duration: 0.2s;
}

.level-item--boss {
    background-color: rgb(120, 86, 10);
    scale: 1.1 1.1;
}

.level-item--boss:hover {
    background-color: rgb(95, 56, 8);
}

.level-item--super-boss {
    background-color: rgb(80, 10, 100);
    scale: 1.1 1.1;
}

.level-item--super-boss:hover {
    background-color: rgb(60, 8, 75);
}

.level-item__name {
    flex-grow: 1;
    -unity-text-align: middle-center;
    -unity-font-style: bold;
    font-size: 45px;
}

.primary-button {
    flex-grow: 1;
    width: 50%;
    align-self: center;
    -unity-font-style: bold;
    font-size: 57px;
    background-color: rgb(152, 51, 51);
    color: var(--color-text-light);
    transition-property: scale;
    transition-duration: 0.1s;
    transition-timing-function: ease-out;
    border-width: 0;
}

.primary-button:hover {
    background-color: rgb(123, 42, 42);
}

.primary-button:active {
    scale: 0.95;
}

.hud-text-h1 {
    color: rgb(243, 243, 243);
    font-size: 35px;
    -unity-font-style: bold;
}
